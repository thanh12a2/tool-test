      <!-- ============================================================
           TG-06: STRESS TEST - Full User Journey
           ============================================================
           ID          : TG-06
           Loại        : Stress Test
           Số user     : 50
           Ramp-up     : 120s (thêm 1 user mỗi 2.4s)
           Iterations  : 5 vòng/user
           Trạng thái  : DISABLED
           Mục đích    : Tìm điểm giới hạn của hệ thống bằng cách mô phỏng
                         50 người dùng đồng thời thực hiện toàn bộ luồng từ
                         đăng nhập đến đặt lịch hẹn.
           Liên quan   : A-NF-TC01, A-NF-TC06 (hoàn thành trong 3 phút)
           ============================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG-06: [STRESS] Full User Journey - 50 Users" enabled="false">
        <stringProp name="TestPlan.comments">
          STRESS TEST - Toàn bộ luồng người dùng
          50 user đồng thời: Login -> Home -> Search -> Tạo lịch hẹn -> Xem lịch sử
          Mục tiêu: Xác định throughput tối đa và điểm hệ thống bắt đầu degradation.
          Số user: 50 | Ramp-up: 120s | Loops: 5
          CẢNH BÁO: Tạo tải cao, chỉ chạy trong môi trường test!
        </stringProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">5</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">50</stringProp>
        <stringProp name="ThreadGroup.ramp_time">120</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- JWT Header -->
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                       testname="[TG-06] Auth Header - Bearer JWT" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer ${JWT_TOKEN}</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <!-- Step 1: Home - Lấy chuyên khoa -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-STRESS-01: [Step 1] GET Chuyên khoa (Home load)" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-STRESS-01
            Liên quan   : A-F-07-TC02, A-NF-TC06
            Loại test   : Stress Test
            Mô tả       : Bước 1 trong luồng stress test. Mô phỏng user mở app -&gt; load trang Home.
            Kỳ vọng     : HTTP 200 ngay cả dưới tải 50 users đồng thời.
            Endpoint    : GET /api/specialties
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/specialties</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 3000ms (stress threshold)" enabled="true">
            <longProp name="DurationAssertion.duration">3000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- Think time giữa steps -->
        <GaussianRandomTimer guiclass="GaussianRandomTimerGui" testclass="GaussianRandomTimer"
                             testname="Think Time: Random 500-1500ms (user behavior)" enabled="true">
          <stringProp name="ConstantTimer.delay">500</stringProp>
          <stringProp name="RandomTimer.range">1000</stringProp>
        </GaussianRandomTimer>
        <hashTree/>

        <!-- Step 2: Search -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-STRESS-02: [Step 2] GET Tìm kiếm bác sĩ" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-STRESS-02
            Liên quan   : A-NF-TC06 (Hoàn thành toàn bộ luồng trong 3 phút)
            Loại test   : Stress Test
            Mô tả       : Bước 2 trong luồng stress test. Mô phỏng user tìm kiếm bác sĩ/chuyên khoa.
            Endpoint    : GET /api/doctors?page=0&amp;size=10
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="page" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">page</stringProp>
                <stringProp name="Argument.value">0</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="size" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">size</stringProp>
                <stringProp name="Argument.value">10</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/doctors</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 3000ms" enabled="true">
            <longProp name="DurationAssertion.duration">3000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- Think time -->
        <GaussianRandomTimer guiclass="GaussianRandomTimerGui" testclass="GaussianRandomTimer"
                             testname="Think Time: Random 800-2800ms" enabled="true">
          <stringProp name="ConstantTimer.delay">800</stringProp>
          <stringProp name="RandomTimer.range">2000</stringProp>
        </GaussianRandomTimer>
        <hashTree/>

        <!-- Step 3: Tạo lịch hẹn -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-STRESS-03: [Step 3] POST Tạo lịch hẹn (concurrent)" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-STRESS-03
            Liên quan   : A-F-02-TC04 (Trùng lịch - FAIL), A-NF-TC01, A-NF-TC06
            Loại test   : Stress Test
            Mô tả       : Bước 3 - 50 users đồng thời tạo lịch hẹn.
                          Đây là test quan trọng nhất: kiểm tra race condition khi nhiều
                          người đặt cùng giờ khám cùng lúc. Bug A-F-02-TC04 chưa fix ->
                          nhiều lịch trùng giờ sẽ được tạo thành công.
                          Theo dõi error rate và response time degradation.
            Endpoint    : POST /api/appointments
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{
  "bookerName": "Test User ${__threadNum}",
  "bookerPhone": "09012345${__threadNum}",
  "patientName": "Test Patient ${__threadNum}",
  "patientGender": "MALE",
  "patientDob": "1990-01-01",
  "patientAddress": "Ha Noi",
  "reason": "Performance test - thread ${__threadNum}",
  "specialtyId": 1,
  "appointmentDate": "2026-07-01",
  "appointmentTime": "09:00"
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/appointments</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 5000ms (stress - nới lỏng)" enabled="true">
            <longProp name="DurationAssertion.duration">5000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- Step 4: Xem lịch sử -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-STRESS-04: [Step 4] GET Lịch sử lịch hẹn" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-STRESS-04
            Liên quan   : A-F-04-TC01, A-NF-TC01
            Loại test   : Stress Test
            Mô tả       : Bước 4 - Xem lịch sử sau khi tạo lịch hẹn.
                          Kết thúc luồng stress test. Đo tổng thời gian toàn bộ luồng.
            Endpoint    : GET /api/appointments
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
