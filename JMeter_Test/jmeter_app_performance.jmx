      <!-- ============================================================
           TG-07: SECURITY TEST - JWT Token Validation
           ============================================================
           ID          : TG-07
           Loại        : Security Test
           Số user     : 5
           Ramp-up     : 5s
           Iterations  : 3 vòng/user
           Trạng thái  : DISABLED
           Mục đích    : Xác minh backend xử lý đúng các JWT invalid/expired
           Liên quan   : A-NF-TC03 (JWT hợp lệ), A-NF-TC04 (JWT hết hạn)
           ============================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG-07: [SECURITY] JWT Token Validation Tests" enabled="false">
        <stringProp name="TestPlan.comments">
          SECURITY TEST - JWT Token Validation
          Kiểm tra backend xử lý đúng với valid/invalid/expired JWT.
          Số user: 5 | Ramp-up: 5s | Loops: 3
        </stringProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">3</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">5</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- PERF-SEC-01: Request với JWT hợp lệ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-SEC-01: GET Profile với JWT hợp lệ (A-NF-TC03)" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-SEC-01
            Liên quan   : A-NF-TC03 (Request với JWT hợp lệ - kỳ vọng 200)
            Loại test   : Security Test
            Mô tả       : Gọi API cần xác thực với JWT hợp lệ.
                          Kỳ vọng: backend verify JWT thành công và trả về dữ liệu (HTTP 200).
                          Kiểm tra JWT middleware hoạt động đúng.
            Kỳ vọng     : HTTP 200, có dữ liệu user trong response.
            Endpoint    : GET /api/users/profile (với Authorization: Bearer VALID_JWT)
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/users/profile</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                         testname="Header: Valid JWT" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Authorization</stringProp>
                <stringProp name="Header.value">Bearer ${JWT_TOKEN}</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200 với JWT hợp lệ (A-NF-TC03)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">A-NF-TC03: JWT hợp lệ phải nhận được HTTP 200!</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-SEC-02: Request với JWT không hợp lệ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-SEC-02: GET Profile với JWT không hợp lệ (A-NF-TC04)" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-SEC-02
            Liên quan   : A-NF-TC04 (Request với JWT hết hạn - kỳ vọng 401)
            Loại test   : Security Test
            Mô tả       : Gọi API với JWT giả/hết hạn.
                          Kỳ vọng QUAN TRỌNG: backend phải từ chối (HTTP 401).
                          Nếu backend trả 200 với JWT sai -> lỗ hổng bảo mật nghiêm trọng!
                          Dùng JWT hardcoded giả để test.
            Kỳ vọng     : HTTP 401 Unauthorized (bắt buộc).
            Endpoint    : GET /api/users/profile (với JWT không hợp lệ)
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/users/profile</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                         testname="Header: Invalid/Expired JWT" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Authorization</stringProp>
                <!-- JWT giả - eyJhbGciOiJIUzI1NiJ9 = header, phần còn lại là fake -->
                <stringProp name="Header.value">Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJmYWtlX3VzZXIiLCJleHAiOjE2MDAwMDAwMDB9.INVALID_SIGNATURE_HERE</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>
          <!-- Kỳ vọng PHẢI là 401 - nếu FAIL nghĩa là backend không check JWT -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 401 với JWT không hợp lệ (A-NF-TC04)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">401</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">A-NF-TC04: JWT không hợp lệ PHẢI bị từ chối với HTTP 401! Nếu FAIL = lỗ hổng bảo mật!</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-SEC-03: Request không có Authorization header -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-SEC-03: GET Profile không có JWT (Unauthorized)" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-SEC-03
            Liên quan   : A-NF-TC03, A-NF-TC04
            Loại test   : Security Test
            Mô tả       : Gọi API không có Authorization header hoàn toàn.
                          Backend phải từ chối với 401 hoặc 403.
                          Nếu trả về 200 -> API không được bảo vệ -> lỗ hổng bảo mật.
            Kỳ vọng     : HTTP 401 hoặc 403.
            Endpoint    : GET /api/users/profile (không có token)
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/users/profile</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 401 hoặc 403 (no token)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">401</stringProp>
              <stringProp name="49587">403</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">SECURITY: API profile không được public! Phải yêu cầu xác thực!</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">40</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>
      <!-- END TG-07 -->


