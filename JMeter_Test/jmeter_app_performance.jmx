<?xml version="1.0" encoding="UTF-8"?>
<!--
  =====================================================================
  FILE       : PTIT_Medical_App_Performance_Tests.jmx
  PROJECT    : Hệ thống Hỗ trợ Đặt lịch & Điều trị Y tế - PTIT
  TEAM       : Nhóm QA - PTIT Graduation Project
  BASE URL   : http://192.168.1.221:8080/PTIT-Do-An-Tot-Nghiep
  CREATED    : 2026-05-06
  TOOL       : Apache JMeter 5.6+

  MÔ TẢ     : File kiểm thử hiệu năng toàn diện bao gồm:
               - Smoke Test: Kiểm tra kết nối cơ bản
               - Load Test : Mô phỏng tải thực tế (10-30 user)
               - Stress Test: Tìm điểm giới hạn hệ thống (50 user)
               - Security Test: Kiểm tra xác thực JWT


  THỨ TỰ CHẠY ĐỀ XUẤT:
    Bước 1 : TG-01 Smoke Test (kiểm tra server sống không)
    Bước 2 : TG-02 Load Auth (test đăng nhập)
    Bước 3 : TG-03 Load Appointment (test lịch hẹn)
    Bước 4 : TG-04 Load Home & Search (test tìm kiếm)
    Bước 5 : TG-05 Load Notification & Profile
    Bước 6 : TG-06 Stress Test Full Flow
  =====================================================================
-->
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>

    <!-- ============================================================
         TEST PLAN
         ============================================================ -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan"
              testname="PTIT Medical App - Performance Test Plan" enabled="true">
      <stringProp name="TestPlan.comments">
        Kế hoạch kiểm thử hiệu năng cho hệ thống đặt lịch y tế PTIT.
        Bao gồm Smoke / Load / Stress / Security tests.
        Liên quan functional test: A-F-01 đến A-F-14, A-NF-TC01 đến A-NF-TC08
      </stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <!-- serialize_threadgroups=true: các Thread Group chạy tuần tự -->
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>

      <!-- ====== BIẾN TOÀN CỤC (User Defined Variables) ====== -->
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments"
                   guiclass="ArgumentsPanel" testclass="Arguments"
                   testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments">

          <!-- Server configuration -->
          <elementProp name="HOST" elementType="Argument">
            <stringProp name="Argument.name">HOST</stringProp>
            <stringProp name="Argument.value">192.168.1.9</stringProp>
            <stringProp name="Argument.desc">IP address của backend server</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="PORT" elementType="Argument">
            <stringProp name="Argument.name">PORT</stringProp>
            <stringProp name="Argument.value">80</stringProp>
            <stringProp name="Argument.desc">Port của backend server</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="CONTEXT_PATH" elementType="Argument">
            <stringProp name="Argument.name">CONTEXT_PATH</stringProp>
            <stringProp name="Argument.value">/PTIT-Do-An-Tot-Nghiep</stringProp>
            <stringProp name="Argument.desc">Context path của ứng dụng</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="API_BASE" elementType="Argument">
            <stringProp name="Argument.name">API_BASE</stringProp>
            <stringProp name="Argument.value">${CONTEXT_PATH}/api</stringProp>
            <stringProp name="Argument.desc">Prefix của tất cả API endpoints</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- Test data -->
          <elementProp name="TEST_PHONE" elementType="Argument">
            <stringProp name="Argument.name">TEST_PHONE</stringProp>
            <stringProp name="Argument.value">0901234567</stringProp>
            <stringProp name="Argument.desc">Số điện thoại test (thay bằng SĐT thực)</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="TEST_OTP" elementType="Argument">
            <stringProp name="Argument.name">TEST_OTP</stringProp>
            <stringProp name="Argument.value">123456</stringProp>
            <stringProp name="Argument.desc">OTP test (thay bằng OTP thực từ SMS)</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="JWT_TOKEN" elementType="Argument">
            <stringProp name="Argument.name">JWT_TOKEN</stringProp>
            <stringProp name="Argument.value">REPLACE_WITH_VALID_JWT</stringProp>
            <stringProp name="Argument.desc">JWT token - tự động cập nhật sau khi login thành công</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="TEST_APPOINTMENT_ID" elementType="Argument">
            <stringProp name="Argument.name">TEST_APPOINTMENT_ID</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.desc">ID lịch hẹn mẫu để test</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- Performance thresholds (ms) -->
          <elementProp name="RESPONSE_THRESHOLD_MS" elementType="Argument">
            <stringProp name="Argument.name">RESPONSE_THRESHOLD_MS</stringProp>
            <stringProp name="Argument.value">2000</stringProp>
            <stringProp name="Argument.desc">Ngưỡng thời gian phản hồi tối đa (ms) - A-NF-TC01</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

        </collectionProp>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>

    <hashTree>

      <!-- ============================================================
           GLOBAL CONFIG: HTTP Cookie Manager
           Tự động quản lý cookie session cho mọi request
           ============================================================ -->
      <CookieManager guiclass="CookiePanel" testclass="CookieManager"
                     testname="[Global] HTTP Cookie Manager" enabled="true">
        <collectionProp name="CookieManager.cookies"/>
        <boolProp name="CookieManager.clearEachIteration">true</boolProp>
        <boolProp name="CookieManager.controlledByThreadGroup">false</boolProp>
      </CookieManager>
      <hashTree/>

      <!-- ============================================================
           GLOBAL CONFIG: HTTP Header Manager
           Đặt Content-Type và Accept mặc định cho tất cả requests
           ============================================================ -->
      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                     testname="[Global] HTTP Header Manager - JSON" enabled="true">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Content-Type</stringProp>
            <stringProp name="Header.value">application/json</stringProp>
          </elementProp>
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Accept</stringProp>
            <stringProp name="Header.value">application/json</stringProp>
          </elementProp>
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Accept-Charset</stringProp>
            <stringProp name="Header.value">UTF-8</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>

      <!-- ============================================================
           GLOBAL CONFIG: HTTP Request Defaults
           Cấu hình mặc định cho tất cả HTTP requests
           ============================================================ -->
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement"
                         testname="[Global] HTTP Request Defaults" enabled="true">
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                     guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
        <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
        <stringProp name="HTTPSampler.port">${PORT}</stringProp>
        <stringProp name="HTTPSampler.protocol">http</stringProp>
        <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
        <stringProp name="HTTPSampler.path"></stringProp>
        <stringProp name="HTTPSampler.concurrentPool">6</stringProp>
        <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
        <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
      </ConfigTestElement>
      <hashTree/>


      <!-- ============================================================
           TG-01: SMOKE TEST - Kiểm tra kết nối cơ bản
           ============================================================
           ID          : TG-01
           Loại        : Smoke Test
           Số user     : 1
           Ramp-up     : 1s
           Iterations  : 1
           Trạng thái  : ENABLED (chạy mặc định)
           Mục đích    : Xác nhận server đang chạy và các API cơ bản phản hồi
           Liên quan   : A-F-07, A-F-06, A-NF-TC01
           ============================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG-01: [SMOKE] Kiểm tra kết nối cơ bản" enabled="true">
        <stringProp name="TestPlan.comments">
          SMOKE TEST - Chạy trước tất cả các test khác để xác nhận server hoạt động.
          Nếu TG-01 FAIL thì không cần chạy các TG tiếp theo.
          Số user: 1 | Loops: 1 | Không có delay
        </stringProp>
        <stringProp name="ThreadGroup.on_sample_error">stoptest</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.duration"></stringProp>
        <stringProp name="ThreadGroup.delay"></stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- PERF-HOME-01: Lấy danh sách chuyên khoa -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-HOME-01: GET Danh sách chuyên khoa" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-HOME-01
            Liên quan   : A-F-07-TC02 (Hiển thị danh mục chuyên khoa trên Home)
            Loại test   : Smoke / Load
            Mô tả       : Lấy toàn bộ danh sách chuyên khoa y tế để hiển thị trên màn hình Home.
                          Đây là API công khai, không cần xác thực.
            Kỳ vọng     : HTTP 200, response time &lt; 2000ms, JSON array không rỗng.
            Endpoint    : GET /api/specialties 
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/specialties</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">PERF-HOME-01: API chuyên khoa phải trả về 200</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-HOME-02: Lấy danh sách bác sĩ nổi bật -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-HOME-02: GET Bác sĩ nổi bật" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-HOME-02
            Liên quan   : A-F-07-TC03 (Hiển thị danh sách bác sĩ nổi bật trên Home)
            Loại test   : Smoke / Load
            Mô tả       : Lấy danh sách bác sĩ nổi bật cho màn hình Home của app.
                          API này thường được gọi khi app khởi động, tạo tải cao ban đầu.
            Kỳ vọng     : HTTP 200, response time &lt; 2000ms, JSON có trường name, specialty, image.
            Endpoint    : GET /api/doctors/
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/doctors/featured</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">PERF-HOME-02: API bác sĩ nổi bật phải trả về 200</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-HOME-03: Lấy toàn bộ danh sách bác sĩ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-HOME-03: GET Tất cả bác sĩ" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-HOME-03
            Liên quan   : A-F-06-TC01, A-F-06-TC02 (Tìm kiếm bác sĩ/chuyên khoa)
            Loại test   : Smoke / Load
            Mô tả       : Lấy toàn bộ danh sách bác sĩ. Đây thường là API nặng nhất do
                          phải trả về nhiều bản ghi. Cần kiểm tra xem backend có phân trang không.
            Kỳ vọng     : HTTP 200, response time &lt; 3000ms.
            Endpoint    : GET /api/doctors?page=0&amp;size=20
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="page" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">page</stringProp>
                <stringProp name="Argument.value">0</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="size" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">size</stringProp>
                <stringProp name="Argument.value">20</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/doctors</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 3000ms" enabled="true">
            <longProp name="DurationAssertion.duration">3000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>
      <!-- END TG-01 -->


      <!-- ============================================================
           TG-02: LOAD TEST - Authentication APIs
           ============================================================
           ID          : TG-02
           Loại        : Load Test
           Số user     : 10
           Ramp-up     : 30s (mỗi 3s thêm 1 user)
           Iterations  : 5 vòng/user
           Trạng thái  : DISABLED - bật thủ công khi cần
           Mục đích    : Kiểm tra hiệu năng API đăng nhập dưới tải đồng thời
           Liên quan   : A-F-01-TC01, A-F-01-TC04, A-NF-TC03, A-NF-TC04
           ============================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG-02: [LOAD] Authentication APIs" enabled="false">
        <stringProp name="TestPlan.comments">
          LOAD TEST - Authentication
          Mô phỏng 10 người dùng đồng thời gọi API đăng nhập.
          Số user: 10 | Ramp-up: 30s | Loops: 5
          Bật thread group này để test riêng phần xác thực.
        </stringProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">5</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">10</stringProp>
        <stringProp name="ThreadGroup.ramp_time">30</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- PERF-AUTH-01: Gửi OTP -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-AUTH-01: POST Yêu cầu gửi OTP" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-AUTH-01
            Liên quan   : A-F-01-TC01 (Đăng nhập bằng OTP hợp lệ)
            Loại test   : Load Test
            Mô tả       : Gọi API yêu cầu gửi OTP về số điện thoại người dùng.
                          Đây là bước đầu tiên trong luồng đăng nhập OTP.
                          Cần kiểm tra xem server có rate-limiting cho endpoint này không
                          (để tránh spam SMS). Dưới tải cao, SMS gateway có thể là bottleneck.
            Kỳ vọng     : HTTP 200, response time &lt; 2000ms.
            Endpoint    : POST /api/auth/otp/request
            Body        : {"phoneNumber": "0901234567"}
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{"phoneNumber": "${TEST_PHONE}"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/auth/otp/request</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">PERF-AUTH-01: Request OTP phải trả về 200</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
          <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer"
                         testname="Think Time: chờ 1s trước khi verify OTP" enabled="true">
            <stringProp name="ConstantTimer.delay">1000</stringProp>
          </ConstantTimer>
          <hashTree/>
        </hashTree>

        <!-- PERF-AUTH-02: Xác thực OTP và lấy JWT -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-AUTH-02: POST Xác thực OTP - Lấy JWT Token" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-AUTH-02
            Liên quan   : A-F-01-TC01 (Đăng nhập OTP hợp lệ), A-NF-TC03 (JWT hợp lệ)
            Loại test   : Load Test
            Mô tả       : Xác thực OTP và nhận JWT token để sử dụng cho các API tiếp theo.
                          Sau request này, JWT_TOKEN sẽ được extract và lưu vào biến.
                          Đây là API quan trọng nhất - nếu chậm sẽ ảnh hưởng toàn bộ luồng.
            Kỳ vọng     : HTTP 200, response time &lt; 2000ms, response có trường "token".
            Endpoint    : POST /api/auth/otp/verify
            Body        : {"phoneNumber": "0901234567", "otp": "123456"}
            NOTE        : Cập nhật TEST_OTP bằng OTP thực trước khi chạy test này.
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{"phoneNumber": "${TEST_PHONE}", "otp": "${TEST_OTP}"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/auth/otp/verify</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Tự động extract JWT token từ response body -->
          <JSONPathExtractor guiclass="JSONPathExtractorGui" testclass="JSONPathExtractor"
                             testname="Extract: JWT Token từ response" enabled="true">
            <stringProp name="JSONPathExtractor.referenceName">JWT_TOKEN</stringProp>
            <stringProp name="JSONPathExtractor.jsonPathExprs">$.token</stringProp>
            <stringProp name="JSONPathExtractor.defaultValues">TOKEN_NOT_FOUND</stringProp>
            <stringProp name="JSONPathExtractor.match_no">0</stringProp>
          </JSONPathExtractor>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">PERF-AUTH-02: Verify OTP phải trả về 200</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-AUTH-03: Google OAuth Login -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-AUTH-03: POST Đăng nhập Google OAuth" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-AUTH-03
            Liên quan   : A-F-01-TC04 (Đăng nhập qua Google Sign-In thành công)
            Loại test   : Load Test
            Mô tả       : Test API nhận Google ID Token và trả về JWT của hệ thống.
                          Thay "GOOGLE_ID_TOKEN_HERE" bằng token thực từ Google OAuth2.
                          API này phụ thuộc vào Google server - response time có thể cao hơn.
            Kỳ vọng     : HTTP 200, response time &lt; 3000ms (có latency tới Google).
            Endpoint    : POST /api/auth/google
            Body        : {"idToken": "...google_id_token..."}
            NOTE        : Cập nhật idToken bằng Google ID Token thực trước khi chạy.
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{"idToken": "GOOGLE_ID_TOKEN_HERE"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/auth/google</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 3000ms" enabled="true">
            <longProp name="DurationAssertion.duration">3000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>
      <!-- END TG-02 -->


      <!-- ============================================================
           TG-03: LOAD TEST - Appointment Management APIs
           ============================================================
           ID          : TG-03
           Loại        : Load Test
           Số user     : 20
           Ramp-up     : 60s
           Iterations  : 3 vòng/user
           Trạng thái  : DISABLED
           Mục đích    : Kiểm tra hiệu năng API quản lý lịch hẹn dưới tải đồng thời.
                         Đây là luồng nghiệp vụ cốt lõi của ứng dụng.
           Liên quan   : A-F-02, A-F-03, A-F-04, A-NF-TC01, A-NF-TC06
           ============================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG-03: [LOAD] Appointment Management APIs" enabled="false">
        <stringProp name="TestPlan.comments">
          LOAD TEST - Appointment Management
          20 người dùng đồng thời thực hiện các thao tác lịch hẹn.
          Số user: 20 | Ramp-up: 60s | Loops: 3
          QUAN TRỌNG: Đặt JWT_TOKEN hợp lệ vào biến trước khi chạy.
        </stringProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">3</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">60</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- Header Manager với JWT cho TG-03 -->
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                       testname="[TG-03] Auth Header - Bearer JWT" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer ${JWT_TOKEN}</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <!-- PERF-APT-01: Lấy danh sách lịch hẹn -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-APT-01: GET Danh sách lịch hẹn của user" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-APT-01
            Liên quan   : A-F-04-TC01 (Xem lịch sử lịch hẹn), A-NF-TC01
            Loại test   : Load Test
            Mô tả       : Lấy danh sách tất cả lịch hẹn của người dùng hiện tại.
                          API này được gọi mỗi khi user mở tab Lịch sử trong app.
                          Cần xác thực JWT. Kiểm tra thời gian phản hồi khi có nhiều user đồng thời.
            Kỳ vọng     : HTTP 200, response time &lt; 2000ms (theo A-NF-TC01), có phân trang.
            Endpoint    : GET /api/appointments
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/appointments</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms (A-NF-TC01)" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
          <!-- Extract appointment ID để dùng trong PERF-APT-03, PERF-APT-04 -->
          <JSONPathExtractor guiclass="JSONPathExtractorGui" testclass="JSONPathExtractor"
                             testname="Extract: Appointment ID đầu tiên" enabled="true">
            <stringProp name="JSONPathExtractor.referenceName">EXTRACTED_APT_ID</stringProp>
            <stringProp name="JSONPathExtractor.jsonPathExprs">$[0].id</stringProp>
            <stringProp name="JSONPathExtractor.defaultValues">${TEST_APPOINTMENT_ID}</stringProp>
            <stringProp name="JSONPathExtractor.match_no">0</stringProp>
          </JSONPathExtractor>
          <hashTree/>
        </hashTree>

        <!-- PERF-APT-02: Tạo lịch hẹn mới -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-APT-02: POST Tạo lịch hẹn mới" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-APT-02
            Liên quan   : A-F-02-TC01 (Tạo lịch hẹn ngày hợp lệ), A-F-02-TC04 (Trùng lịch - BUG)
            Loại test   : Load Test / Stress Test
            Mô tả       : Tạo lịch hẹn mới. Đây là API quan trọng nhất về hiệu năng vì:
                          1. Nhiều user đồng thời đặt lịch cùng thời điểm
                          2. Backend cần xử lý validation phức tạp (trùng giờ, chuyên khoa...)
                          3. Cần ghi database và gửi notification
                          Bug A-F-02-TC04: Backend chưa check trùng lịch -> test này sẽ
                          tạo được nhiều lịch trùng giờ -> dùng để verify bug vẫn còn.
            Kỳ vọng     : HTTP 201, response time &lt; 2000ms.
            Endpoint    : POST /api/appointments
            Body        : JSON với đầy đủ thông tin lịch hẹn
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{
  "bookerName": "Nguyen Van Nam",
  "bookerPhone": "0375158622",
  "patientName": "Nguyen Van Nam",
  "patientGender": "MALE",
  "patientDob": "2004-11-25",
  "patientAddress": "Ha Noi",
  "reason": "Dau bung",
  "specialtyId": 1,
  "appointmentDate": "2026-06-01",
  "appointmentTime": "10:00"
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/appointments</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: HTTP 200 hoặc 201" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
              <stringProp name="49587">201</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">40</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
          <JSONPathExtractor guiclass="JSONPathExtractorGui" testclass="JSONPathExtractor"
                             testname="Extract: Appointment ID mới tạo" enabled="true">
            <stringProp name="JSONPathExtractor.referenceName">NEW_APT_ID</stringProp>
            <stringProp name="JSONPathExtractor.jsonPathExprs">$.id</stringProp>
            <stringProp name="JSONPathExtractor.defaultValues">0</stringProp>
            <stringProp name="JSONPathExtractor.match_no">0</stringProp>
          </JSONPathExtractor>
          <hashTree/>
        </hashTree>

        <!-- Think time giữa các requests -->
        <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer"
                       testname="Think Time: 500ms giữa các request" enabled="true">
          <stringProp name="ConstantTimer.delay">500</stringProp>
        </ConstantTimer>
        <hashTree/>

        <!-- PERF-APT-03: Xem chi tiết lịch hẹn -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-APT-03: GET Chi tiết lịch hẹn theo ID" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-APT-03
            Liên quan   : A-F-04-TC03 (Xem chi tiết từng lịch sử khám)
            Loại test   : Load Test
            Mô tả       : Lấy chi tiết một lịch hẹn cụ thể theo ID.
                          Sử dụng EXTRACTED_APT_ID từ PERF-APT-01 hoặc TEST_APPOINTMENT_ID.
                          API này thường được gọi khi user nhấn vào một lịch hẹn trong danh sách.
            Kỳ vọng     : HTTP 200, response time &lt; 1000ms (query đơn bản ghi nhanh hơn).
            Endpoint    : GET /api/appointments/{id}
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/appointments/${EXTRACTED_APT_ID}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 1500ms" enabled="true">
            <longProp name="DurationAssertion.duration">1500</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-APT-04: Hủy lịch hẹn -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-APT-04: PUT Hủy lịch hẹn" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-APT-04
            Liên quan   : A-F-03-TC01 (Hủy lịch hẹn ở trạng thái Đang xử lý)
            Loại test   : Load Test
            Mô tả       : Hủy lịch hẹn đang ở trạng thái PENDING/ĐANG XỬ LÝ.
                          Sử dụng NEW_APT_ID từ PERF-APT-02 (lịch vừa tạo).
                          Backend cần validate: chỉ cho hủy khi trạng thái là PENDING,
                          không cho hủy khi đã CONFIRMED (A-F-03-TC02 PASS).
            Kỳ vọng     : HTTP 200, response time &lt; 1500ms.
            Endpoint    : PUT /api/appointments/{id}/cancel (hoặc DELETE)
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/appointments/${NEW_APT_ID}/cancel</stringProp>
          <stringProp name="HTTPSampler.method">PUT</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 1500ms" enabled="true">
            <longProp name="DurationAssertion.duration">1500</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-APT-05: Lấy lịch sử lịch hẹn -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="PERF-APT-05: GET Lịch sử lịch hẹn (History)" enabled="true">
          <stringProp name="TestPlan.comments">
            ID          : PERF-APT-05
            Liên quan   : A-F-04-TC01, A-F-04-TC02, A-F-04-TC03
            Loại test   : Load Test
            Mô tả       : Lấy lịch sử toàn bộ lịch hẹn (đã hoàn thành, đã hủy, đang chờ).
                          API này có thể trả về nhiều bản ghi -> quan trọng để kiểm tra
                          performance khi data lớn. Nên có phân trang.
            Kỳ vọng     : HTTP 200, response time &lt; 2000ms.
            Endpoint    : GET /api/appointments/history hoặc GET /api/appointments?status=all
          </stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <stringProp name="HTTPSampler.path">${API_BASE}/appointments/history</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>
      <!-- END TG-03 -->


      <!-- ============================================================
           TG-04: LOAD TEST - Home & Search APIs
           ============================================================
           ID          : TG-04
           Loại        : Load Test
           Số user     : 30
           Ramp-up     : 60s
           Iterations  : 3 vòng/user
           Trạng thái  : DISABLED
           Mục đích    : Kiểm tra hiệu năng các API trang chủ và tìm kiếm.
                         Đây thường là APIs được gọi nhiều nhất (mỗi lần mở app).
           Liên quan   : A-F-06 (Tìm kiếm - tất cả FAIL do bug), A-F-07
           ============================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG-04: [LOAD] Home &amp; Search APIs" enabled="false">
        <stringProp name="TestPlan.comments">
          LOAD TEST - Home và Search
          30 người dùng đồng thời. Đây là số lượng request cao nhất vì API home
          được gọi khi mở app. Thanh tìm kiếm bị BUG (A-F-06 toàn FAIL) nhưng
          vẫn test API backend để verify bug nằm ở frontend hay backend.
          Số user: 30 | Ramp-up: 60s | Loops: 3
        </stringProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">3</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">30</stringProp>
        <stringProp name="ThreadGroup.ramp_time">60</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- PERF-SEARCH-01: Tìm kiếm bác sĩ theo tên -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
