          <DurationAssertion guiclass="DurationAssertionGui"
                             testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 3000ms" enabled="true">
            <longProp name="DurationAssertion.duration">3000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-WEB-TC20 | Viết bệnh án -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui"
                          testclass="HTTPSamplerProxy"
                          testname="PERF-WEB-TC20 | POST /medical-records/create – Viết bệnh án"
                          enabled="true">
          <stringProp name="TestPlan.comments">
            ID       : PERF-WEB-TC20
            Chức năng: Bác sĩ lưu bệnh án cho lịch khám. Sau khi lưu, app Android của
                       bệnh nhân phải hiển thị được → kiểm tra write performance.
                       Lưu ý: W-F-11-TC05 FAIL vì lỗi SQLSTATE[22001] khi nội dung dài.
            Kiểm tra : HTTP 200/302; response time &lt; 3000ms; không lỗi DB truncation.
            Liên quan: W-F-11-TC01 (Viết bệnh án – PASS), W-F-11-TC05 (FAIL)
          </stringProp>
          <stringProp name="HTTPSampler.path">${BASE_PATH}/medical-records/create</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="schedule_id" elementType="HTTPArgument">
                <stringProp name="Argument.name">schedule_id</stringProp>
                <stringProp name="Argument.value">1</stringProp>
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
              </elementProp>
              <elementProp name="status_before" elementType="HTTPArgument">
                <stringProp name="Argument.name">status_before</stringProp>
                <stringProp name="Argument.value">Bệnh nhân mệt mỏi, sốt nhẹ 37.5 độ</stringProp>
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
              <elementProp name="status_after" elementType="HTTPArgument">
                <stringProp name="Argument.name">status_after</stringProp>
                <stringProp name="Argument.value">Bệnh nhân ổn định sau khám</stringProp>
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
              <elementProp name="reason" elementType="HTTPArgument">
                <stringProp name="Argument.name">reason</stringProp>
                <stringProp name="Argument.value">Cảm cúm thông thường</stringProp>
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
              <elementProp name="description" elementType="HTTPArgument">
                <stringProp name="Argument.name">description</stringProp>
                <stringProp name="Argument.value">Nghỉ ngơi, uống nhiều nước, tái khám sau 3 ngày</stringProp>
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui"
                             testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 3000ms" enabled="true">
            <longProp name="DurationAssertion.duration">3000</longProp>
          </DurationAssertion>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert: Không có lỗi 500 (DB truncation)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49588">500</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">6</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

      </hashTree><!-- end TG-05 -->

