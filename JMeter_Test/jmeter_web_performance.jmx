      <!-- ────────────────────────────────────────────────────────
           TG-03 | QUẢN LÝ CHUYÊN KHOA – CRUD
           ID nhóm : PERF-WEB-TG03
           Mục đích: Kiểm tra hiệu năng create/update/delete chuyên khoa.
                     Là dữ liệu master, ít write nhưng phải đúng.
           Kịch bản: 10 threads, ramp 10s, lặp 3 lần.
           ──────────────────────────────────────────────────────── -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG-03 | Quản lý Chuyên khoa CRUD (10 users)"
                   enabled="true">
        <stringProp name="TestPlan.comments">
          PERF-WEB-TG03 – Kiểm tra CRUD Chuyên khoa dưới tải concurrent.
          Phát hiện race condition hoặc deadlock khi nhiều admin sửa cùng lúc.
        </stringProp>
        <intProp name="ThreadGroup.num_threads">10</intProp>
        <intProp name="ThreadGroup.ramp_time">10</intProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController">
          <intProp name="LoopController.loops">3</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>

        <!-- PERF-WEB-TC11 | Tạo chuyên khoa mới -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui"
                          testclass="HTTPSamplerProxy"
                          testname="PERF-WEB-TC11 | POST /specialities – Tạo chuyên khoa"
                          enabled="true">
          <stringProp name="TestPlan.comments">
            ID       : PERF-WEB-TC11
            Chức năng: Gửi request tạo mới chuyên khoa. Kiểm tra write performance,
                       transaction isolation và không bị duplicate khi concurrent insert.
            Kiểm tra : HTTP 200/201/302; response time &lt; 2000ms; không lỗi DB.
            Liên quan: W-F-13-TC01 (Tạo chuyên khoa mới hợp lệ – PASS)
          </stringProp>
          <stringProp name="HTTPSampler.path">${BASE_PATH}/specialities/create</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="name" elementType="HTTPArgument">
                <stringProp name="Argument.name">name</stringProp>
                <stringProp name="Argument.value">Chuyên khoa Test ${__threadNum}</stringProp>
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
              <elementProp name="description" elementType="HTTPArgument">
                <stringProp name="Argument.name">description</stringProp>
                <stringProp name="Argument.value">Mô tả tự động JMeter thread ${__threadNum}</stringProp>
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui"
                             testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-WEB-TC12 | Cập nhật chuyên khoa -->
