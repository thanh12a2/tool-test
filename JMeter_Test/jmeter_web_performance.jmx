                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
              <elementProp name="description" elementType="HTTPArgument">
                <stringProp name="Argument.name">description</stringProp>
                <stringProp name="Argument.value">Khám bệnh nội khoa tổng quát</stringProp>
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <DurationAssertion guiclass="DurationAssertionGui"
                             testclass="DurationAssertion"
                             testname="Assert: Response time &lt; 2000ms" enabled="true">
            <longProp name="DurationAssertion.duration">2000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- PERF-WEB-TC13 | Xóa chuyên khoa -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui"
                          testclass="HTTPSamplerProxy"
                          testname="PERF-WEB-TC13 | POST /specialities/delete – Xóa"
                          enabled="true">
          <stringProp name="TestPlan.comments">
            ID       : PERF-WEB-TC13
            Chức năng: Xóa chuyên khoa. Kiểm tra DELETE có kiểm tra FK constraint không
                       (chuyên khoa đang được dùng bởi bác sĩ không nên xóa được).
                       Đo thời gian xử lý constraint check.
            Kiểm tra : HTTP 200/302; response time &lt; 2000ms; không lỗi 500.
            Liên quan: W-F-13-TC03 (Xóa chuyên khoa – PASS)
          </stringProp>
          <stringProp name="HTTPSampler.path">${BASE_PATH}/specialities/delete</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
