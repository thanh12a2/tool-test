                          testclass="HTTPSamplerProxy"
                          testname="PERF-WEB-TC12 | POST /specialities/1/edit – Cập nhật"
                          enabled="true">
          <stringProp name="TestPlan.comments">
            ID       : PERF-WEB-TC12
            Chức năng: Cập nhật thông tin chuyên khoa ID=1. Kiểm tra UPDATE performance.
                       Lưu ý: W-F-13-TC02 FAIL vì form description bị reset → cần monitor.
            Kiểm tra : HTTP 200/302; response time &lt; 2000ms.
            Liên quan: W-F-13-TC02 (Sửa chuyên khoa – FAIL)
          </stringProp>
          <stringProp name="HTTPSampler.path">${BASE_PATH}/specialities/1/edit</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
